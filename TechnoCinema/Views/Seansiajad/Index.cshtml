<a asp-action="Create" class="btn btn-primary mb-3">Lisa uus seanss</a>
<a asp-action="EditedList" class="btn btn-primary mb-3">Edit</a>


<h2>Seansiajad</h2>          

<form method="get" class="mb-3">
    <input type="text" name="searchString" placeholder="Otsi filmi"
           value="@ViewBag.SearchString" class="form-control" />
    <button type="submit" class="btn btn-primary mt-2">Otsi</button>
</form>

<div class="layout">
    <!-- LEFT SIDEBAR -->
    <div class="kino-sidebar">

        <a href="?kino="
           class="kino-item @(string.IsNullOrEmpty(ViewBag.SelectedKino) ? "active" : "")">
            Kõik kinod
            <span class="count">@Model.Count</span>
        </a>

        @foreach (var kino in ViewBag.Kinod)
        {
            <a href="?kino=@kino"
               class="kino-item @(kino == ViewBag.SelectedKino ? "active" : "")">

                <span class="kino-name">@kino</span>

                <span class="count">
                    @(ViewBag.KinoCounts.ContainsKey(kino)
                                    ? ViewBag.KinoCounts[kino]
                                    : 0)
            </span>

            </a>
                }
                
    </div>
<!-- do the seans and the creat html and CSS good do views -->
<div class="row">
    @foreach (var seans in Model)
    {
        <div class="col-md-6 mb-4">
            <div class="card seans-card">


                <!-- aad this when u clik on the name u go do the diteils -->
                <div class="card-header text-white text-center">
                    @seans.Film
                </div>

                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h3>@seans.ReleaseDate.ToShortTimeString()</h3>


                        <a asp-action="Edit" asp-route-id="@seans.Id" class="btn btn-warning">Edit</a>

                        <!-- butten for buy a ticket/piletid -->
                        <a asp-controller="Buy" asp-action="Index" asp-route-id="@seans.Id" class="btn btn-warning">Osta pileteid</a>


                    </div>
                    <p>KinoNimi: @seans.KinoNimi</p>
                    <p>Saal: @seans.Saal</p>
                    <div class="d-flex justify-content-between">
                        <span>Vabu kohti: @seans.VabuKohti</span>
                        <span>Kuupäev: @seans.ReleaseDate.ToShortDateString()</span>
                        <span>Formaat: @seans.Formaat</span>
                        <span>Keel: @seans.Keel</span>
                        <span>Subtiitrid: @seans.Subtiitrid</span>
                    </div>
                </div>
            </div>
        </div>
    }
    <!-- Butten for pageses -->

    <div class="pagination-container text-center mt-4">
        @if (ViewBag.CurrentPage > 1)
        {
            <a class="btn btn-outline-secondary" href="?page=@(ViewBag.CurrentPage - 1)">Previous</a>
        }
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
        if
        (i == ViewBag.CurrentPage)
        {<span class="btn btn-primary disabled">@i</span>}
         else
        {<a class="btn btn-outline-primary" href="?page=@i">@i</a>}
        }
        @if
        (ViewBag.CurrentPage < ViewBag.TotalPages){
        <a class="btn btn-outline-secondary" href="?page=@(ViewBag.CurrentPage + 1)">Next</a>
        }
    </div>


    <!-- CSS down do -->
</div>


