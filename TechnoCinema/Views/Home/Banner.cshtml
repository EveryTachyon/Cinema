@model List<TechnoCinema.Models.Banner>

<h2>Banner List</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Image</th>
            <th>Position</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var banner in Model)
        {
            <tr>
                
                <td>@banner.Name</td>

                <td><img src="@banner.ImageUrl" width="150" /></td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@banner.Id"
                       class="btn btn-warning btn-sm">
                        Edit
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
